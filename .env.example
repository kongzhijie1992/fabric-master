# Public site URL (used in SEO metadata, sitemap, canonical links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Static RFQ behavior
# If NEXT_PUBLIC_RFQ_ENDPOINT is empty, form submission opens local mail client draft.
# If NEXT_PUBLIC_RFQ_ENDPOINT is set, form posts multipart data to that external endpoint.
NEXT_PUBLIC_RFQ_ENDPOINT=
NEXT_PUBLIC_RFQ_EMAIL=sales@example.com

# Optional static asset base for OSS/COS/CDN (no trailing slash recommended)
ASSET_BASE_URL=
# NEXT_PUBLIC_ASSET_BASE_URL is accepted as alias for static builds
NEXT_PUBLIC_ASSET_BASE_URL=

# Optional analytics (China-friendly)
BAIDU_TONGJI_ID=
NEXT_PUBLIC_BAIDU_TONGJI_ID=

# Optional Tencent captcha (client-side challenge only in pure static mode)
TENCENT_CAPTCHA_APP_ID=
NEXT_PUBLIC_TENCENT_CAPTCHA_APP_ID=
TENCENT_CAPTCHA_APP_SECRET=

# Legacy server-side variables (ignored for pure OSS static hosting)
LEADS_STORE=./data/leads.json
EMAIL_PROVIDER=none
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
FEISHU_WEBHOOK_URL=
WECOM_WEBHOOK_URL=
