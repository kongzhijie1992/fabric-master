# Public site URL (used in SEO metadata, sitemap, canonical links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only lead storage path for local/dev
LEADS_STORE=./data/leads.json

# Optional static asset base for OSS/COS/CDN (no trailing slash recommended)
ASSET_BASE_URL=

# Notification channel: none | smtp
EMAIL_PROVIDER=none
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional chat webhook notifications
FEISHU_WEBHOOK_URL=
WECOM_WEBHOOK_URL=

# Optional analytics (China-friendly)
BAIDU_TONGJI_ID=

# Optional Tencent captcha (if set, frontend renders challenge + backend verifies)
TENCENT_CAPTCHA_APP_ID=
TENCENT_CAPTCHA_APP_SECRET=
