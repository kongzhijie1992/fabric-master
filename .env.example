# Public site URL (used in SEO metadata, sitemap, canonical links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# RFQ API endpoint (same origin example)
# For true server-side sending, point this to your running Next.js API route.
NEXT_PUBLIC_RFQ_ENDPOINT=http://localhost:3000/api/rfq/
NEXT_PUBLIC_RFQ_EMAIL=publicrelations@timelessclothinggroup.com.cn

# Optional static asset base for OSS/COS/CDN (no trailing slash recommended)
ASSET_BASE_URL=
# NEXT_PUBLIC_ASSET_BASE_URL is accepted as alias for static builds
NEXT_PUBLIC_ASSET_BASE_URL=

# Optional analytics (China-friendly)
BAIDU_TONGJI_ID=
NEXT_PUBLIC_BAIDU_TONGJI_ID=

# Optional Tencent captcha (client-side challenge only in pure static mode)
TENCENT_CAPTCHA_APP_ID=
NEXT_PUBLIC_TENCENT_CAPTCHA_APP_ID=
TENCENT_CAPTCHA_APP_SECRET=

# Server-side RFQ storage/notification settings
# Set EMAIL_PROVIDER=smtp to enable true server-side email sending.
LEADS_STORE=./data/leads.json
EMAIL_PROVIDER=none
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
FEISHU_WEBHOOK_URL=
WECOM_WEBHOOK_URL=
